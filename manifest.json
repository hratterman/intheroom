{
  "manifest_version": 3,
  "name": "In The Room",
  "version": "1.0.0",
  "description": "Live meeting transcription and AI summaries. Floats across every tab. No account, no server, nothing leaves your machine.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "In The Room"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "116"
}
